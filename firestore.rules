rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ---------- Helpers ---------- */
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // rider who owns the ride
    function isRideOwner() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // the driver this ride currently targets (driver_requested state)
    function isTargetedDriver() {
      return isSignedIn()
        && resource.data.driverPreferred is map
        && resource.data.driverPreferred.id == request.auth.uid;
    }

    // the driver currently assigned to the ride
    function isAssignedDriver() {
      return isSignedIn()
        && resource.data.driver is map
        && resource.data.driver.id == request.auth.uid;
    }

    // convenience: have only these keys changed?
    function changedOnly(keys) {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(keys);
    }

    // Membership via users/{uid}.joinedCommunities (array of community IDs)
    function isMemberByUserDoc(communityId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.joinedCommunities is list)
        && (communityId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.joinedCommunities);
    }

    // Membership via group chat's members array (so users in the group can send/receive even if joinedCommunities missing)
    function isMemberOfGroupChat(communityId, chatId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/communities/$(communityId)/groupChats/$(chatId))
        && get(/databases/$(database)/documents/communities/$(communityId)/groupChats/$(chatId)).data.members is list
        && request.auth.uid in get(/databases/$(database)/documents/communities/$(communityId)/groupChats/$(chatId)).data.members;
    }

    function isBusinessOwner(businessId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/businesses/$(businessId))
        && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid;
    }

    function canCreateCommunityGroups(communityId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/communities/$(communityId))
        && (
          get(/databases/$(database)/documents/communities/$(communityId)).data.createdBy == request.auth.uid
          || (
            isMemberByUserDoc(communityId)
            && get(/databases/$(database)/documents/communities/$(communityId)).data.get('allowMembersToCreateGroups', false) == true
          )
        );
    }

    // Check if user is a chat participant (supports both array and map formats)
    // For get/update operations
    function isChatParticipant(chatId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/chats/$(chatId))
        && (
          (
            get(/databases/$(database)/documents/chats/$(chatId)).data.participants is list
            && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          ) ||
          (
            get(/databases/$(database)/documents/chats/$(chatId)).data.participants is map
            && get(/databases/$(database)/documents/chats/$(chatId)).data.participants[request.auth.uid] == true
          )
        );
    }

    // Check if user is participant using resource data (for list queries)
    function isParticipantInResource() {
      return isSignedIn()
        && resource.data.participants != null
        && (
          (resource.data.participants is list && request.auth.uid in resource.data.participants) ||
          (resource.data.participants is map && resource.data.participants[request.auth.uid] == true)
        );
    }

    /* ---------- Users ---------- */
    match /users/{userId} {
      // allow collection reads & doc reads for everyone
      allow read: if true;

      // Owner can create/update their own profile
      allow create: if isSignedIn() && request.auth.uid == userId;

      // Update rules:
      // 1. Owner can update their own profile
      // 2. Other users can add themselves to the friends map (for friend request acceptance)
      // Using map structure: friends: { [userId]: true }
      allow update: if isSignedIn() && (
        // Owner updating their own document
        request.auth.uid == userId ||
        // Other user adding themselves to friends map (friend request acceptance)
        (
          // Use changedKeys (top-level) so nested friend map entries don't fail this check.
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['friends']) &&
          request.resource.data.friends is map &&
          request.resource.data.friends[request.auth.uid] == true &&
          (resource.data.friends == null ||
           !(resource.data.friends is map) ||
           request.resource.data.friends.keys().hasAll(resource.data.friends.keys()))
        ) ||
        // Any user can add one chatId to another user's chatIds
        (
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['chatIds']) &&
          request.resource.data.chatIds is list &&
          (resource.data.get('chatIds', []) is list || !('chatIds' in resource.data)) &&
          request.resource.data.chatIds.hasAll(resource.data.get('chatIds', [])) &&
          request.resource.data.chatIds.size() == resource.data.get('chatIds', []).size() + 1
        )
      );
      allow delete: if false;
    }

    match /users/{userId}/wallets/{walletId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /walletTransactions/{transactionId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.uid;
      allow create, update, delete: if false;
    }

    /* ---------- Chats (one-to-one) ---------- */
    match /chats/{chatId} {
      allow get, update: if isChatParticipant(chatId);

      allow list: if isSignedIn() && (
        (resource.data.participants is list && request.auth.uid in resource.data.participants) ||
        (resource.data.participants is map && resource.data.participants[request.auth.uid] == true)
      );

      allow create: if isSignedIn() && (
        (request.resource.data.participants is list && request.auth.uid in request.resource.data.participants) ||
        (request.resource.data.participants is map && request.resource.data.participants[request.auth.uid] == true)
      );

      allow delete: if false;

      match /messages/{messageId} {
        allow get: if isChatParticipant(chatId);
        allow list: if isChatParticipant(chatId);
        allow create: if isChatParticipant(chatId)
          && (
            request.resource.data.senderId == request.auth.uid
            || request.resource.data.senderUid == request.auth.uid
          );
        allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
        allow update: if isSignedIn() && resource.data.senderId == request.auth.uid;
      }
    }

    /* ---------- Businesses ---------- */
    match /businesses/{businessId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isBusinessOwner(businessId);

      match /catalog/{itemId} {
        allow get, list: if true;
        allow create, update, delete: if isBusinessOwner(businessId);
      }

      match /menu/{itemId} {
        allow get, list: if true;
        allow create, update, delete: if isBusinessOwner(businessId);
      }
    }

    /* ---------- Orders ---------- */
    function validOrderStatus(s) {
      return s is string &&
        s in ['payment_pending', 'paid', 'preparing', 'ready', 'completed', 'cancelled'];
    }

    function canAdvanceStatus(old, next) {
      return
        (old == 'payment_pending' && next in ['paid', 'cancelled']) ||
        (old == 'paid'            && next in ['preparing', 'cancelled']) ||
        (old == 'preparing'       && next in ['ready', 'cancelled']) ||
        (old == 'ready'           && next == 'completed') ||
        (old == 'completed'      && next == 'completed') ||
        (old == 'cancelled'      && next == 'cancelled');
    }

    function isOrderOwner() {
      return isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    function isOrderBuyer() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function createIsBuyer() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /orders/{orderId} {
      allow get, list: if isOrderOwner() || isOrderBuyer();

      allow create: if createIsBuyer()
        && request.resource.data.keys().hasAll([
             'businessId', 'ownerId', 'userId', 'items', 'total', 'status'
           ])
        && request.resource.data.businessId is string
        && request.resource.data.ownerId  is string
        && request.resource.data.userId   is string
        && request.resource.data.items    is list
        && request.resource.data.total    is number
        && validOrderStatus(request.resource.data.status);

      allow update: if
        (
          isOrderOwner() &&
          changedOnly(['status','updatedAt']) &&
          validOrderStatus(request.resource.data.status) &&
          canAdvanceStatus(resource.data.status, request.resource.data.status)
        )
        ||
        (
          isOrderBuyer() &&
          changedOnly(['status','updatedAt']) &&
          resource.data.status in ['paid','preparing'] &&
          request.resource.data.status == 'cancelled'
        );

      allow delete: if false;
    }

    match /wallet_transfer_requests/{txId} {
      allow create: if isSignedIn();
      allow read:   if isSignedIn();
      allow update, delete: if false;
    }

    /* ---------- Communities ---------- */
    match /communities/{communityId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.createdBy;

      match /groupChats/{chatId} {
        allow get, list: if isSignedIn();

        allow create: if canCreateCommunityGroups(communityId)
        && request.resource.data.keys().hasAny(['name', 'title']);

        allow update: if (
          (
            isMemberByUserDoc(communityId)
            && changedOnly(['members'])
            && (request.resource.data.members is list)
            && !(request.auth.uid in (resource.data.members is list ? resource.data.members : []))
            && (request.auth.uid in request.resource.data.members)
            && request.resource.data.members.size()
              == ((resource.data.members is list ? resource.data.members.size() : 0) + 1)
          )
          ||
          (
            isMemberOfGroupChat(communityId, chatId)
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(['lastMessageText', 'lastMessageSenderId', 'lastMessageTimestamp', 'unreadCount', 'pinnedMessage'])
          )
          ||
          (
            exists(/databases/$(database)/documents/communities/$(communityId))
            && get(/databases/$(database)/documents/communities/$(communityId)).data.createdBy == request.auth.uid
          )
          ||
          (resource.data.createdBy == request.auth.uid)
          ||
          (
            isMemberOfGroupChat(communityId, chatId)
            && changedOnly(['members'])
            && (request.resource.data.members is list)
            && (request.auth.uid in resource.data.members)
            && !(request.auth.uid in request.resource.data.members)
            && request.resource.data.members.size() == resource.data.members.size() - 1
          )
        );

        allow delete: if (
          (isMemberByUserDoc(communityId) && resource.data.createdBy == request.auth.uid)
          ||
          (
            exists(/databases/$(database)/documents/communities/$(communityId))
            && get(/databases/$(database)/documents/communities/$(communityId)).data.createdBy == request.auth.uid
          )
        );

        match /messages/{messageId} {
          allow get, list: if isSignedIn()
            && (isMemberByUserDoc(communityId) || isMemberOfGroupChat(communityId, chatId)
                || (exists(/databases/$(database)/documents/communities/$(communityId))
                    && get(/databases/$(database)/documents/communities/$(communityId)).data.createdBy == request.auth.uid));

          allow create: if (
            (
              (isMemberByUserDoc(communityId) || isMemberOfGroupChat(communityId, chatId))
              && (
                (request.resource.data.senderId == request.auth.uid) ||
                (request.resource.data.senderUid == request.auth.uid)
              )
            )
            ||
            (
              exists(/databases/$(database)/documents/communities/$(communityId))
              && get(/databases/$(database)/documents/communities/$(communityId)).data.createdBy == request.auth.uid
            )
          );

          allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
          allow update: if isSignedIn() && resource.data.senderId == request.auth.uid;
        }

        match /subscriptionPayments/{memberId} {
          allow read: if isSignedIn()
            && (
              get(/databases/$(database)/documents/communities/$(communityId)/groupChats/$(chatId)).data.createdBy == request.auth.uid
              || (memberId == request.auth.uid && isMemberOfGroupChat(communityId, chatId))
            );
          allow write: if isSignedIn()
            && (
              get(/databases/$(database)/documents/communities/$(communityId)/groupChats/$(chatId)).data.createdBy == request.auth.uid
              || memberId == request.auth.uid
            );
        }
      }

      match /chats/{chatId} {
        allow get, list: if isSignedIn();

        allow create: if canCreateCommunityGroups(communityId)
          && request.resource.data.keys().hasAny(['name', 'title']);

        allow update: if isMemberByUserDoc(communityId)
          && changedOnly(['members'])
          && (request.resource.data.members is list)
          && !(request.auth.uid in (resource.data.members is list ? resource.data.members : []))
          && (request.auth.uid in request.resource.data.members)
          && request.resource.data.members.size()
             == ((resource.data.members is list ? resource.data.members.size() : 0) + 1);

        allow delete: if isMemberByUserDoc(communityId)
          && resource.data.createdBy == request.auth.uid;

        match /messages/{messageId} {
          allow get, list: if isSignedIn();
          allow create: if isMemberByUserDoc(communityId)
            && (
              (request.resource.data.senderId == request.auth.uid) ||
              (request.resource.data.senderUid == request.auth.uid)
            );
          allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
          allow update: if isSignedIn() && resource.data.senderId == request.auth.uid;
        }
      }
    }

    /* ---------- Wallets + Transactions ---------- */
    match /wallets/{userId} {
      allow get, list: if isSelf(userId);
      allow create, update, delete: if false;

      match /transactions/{txId} {
        allow get, list: if isSelf(userId);
        allow create, update, delete: if false;
      }
    }

    match /transactions/{transactionId} {
      allow get, list: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create, update, delete: if false;
    }

    /* ---------- Driver applications/profile ---------- */
    match /driver_applications/{uid} {
      allow read: if isSignedIn();
      allow write: if isSelf(uid);
    }

    match /drivers/{uid} {
      allow read: if true;
      allow write: if isSelf(uid);
    }

    match /drivers_live/{uid} {
      allow read: if true;
      allow write: if isSelf(uid);
    }

    /* ---------- Rides ---------- */
    match /rides/{rideId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        (resource.data.driverPreferred is map && resource.data.driverPreferred.id == request.auth.uid) ||
        (resource.data.driver is map && resource.data.driver.id == request.auth.uid)
      );

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      allow update: if isSignedIn() && (
        (
          isRideOwner()
          && changedOnly(['status','updatedAt'])
          && request.resource.data.status == 'cancelled'
        )
        ||
        (
          isRideOwner()
          && resource.data.status == 'on_trip'
          && changedOnly(['status','updatedAt'])
          && request.resource.data.status == 'completed'
        )
        ||
        (
          isTargetedDriver()
          && resource.data.status == 'driver_requested'
          && (
            (
              request.resource.data.status == 'driver_assigned'
              && request.resource.data.driver is map
              && request.resource.data.driver.id == request.auth.uid
              && (
                   request.resource.data.diff(resource.data).changedKeys().hasOnly(['status','driver','updatedAt'])
                || request.resource.data.diff(resource.data).changedKeys().hasOnly(['status','driver','driverPreferred','updatedAt'])
              )
            )
            ||
            (
              request.resource.data.status == 'driver_declined'
              && request.resource.data.driverPreferred == null
              && changedOnly(['status','driverPreferred','updatedAt'])
            )
          )
        )
        ||
        (
          isAssignedDriver()
          && changedOnly(['status','updatedAt'])
          && (
            (resource.data.status == 'driver_assigned' && request.resource.data.status in ['driver_arrived','on_trip']) ||
            (resource.data.status == 'driver_arrived' && request.resource.data.status == 'on_trip')
          )
        )
      );

      allow delete: if false;
    }

    /* ---------- Group Wallets ---------- */
    match /groupWallets/{groupId} {
      // Read: only members of this group (group chat) can read the wallet (balance, privateKey, passcode hash).
      // Uses communityId stored on the document; backwards compat: creator can always read if doc has no communityId.
      allow read: if isSignedIn() && (
        (
          resource.data.get('communityId', '') is string
          && resource.data.communityId != ''
          && isMemberOfGroupChat(resource.data.communityId, groupId)
        )
        || resource.data.createdBy == request.auth.uid
      );

      // Create: only when creating with yourself as createdBy (group creation flow).
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.communityId is string;

      // Update/delete: only the wallet creator (group admin).
      allow update, delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;

      match /transactions/{txId} {
        allow read: if isSignedIn() && (
          (
            get(/databases/$(database)/documents/groupWallets/$(groupId)).data.get('communityId', '') != ''
            && isMemberOfGroupChat(get(/databases/$(database)/documents/groupWallets/$(groupId)).data.communityId, groupId)
          )
          || get(/databases/$(database)/documents/groupWallets/$(groupId)).data.createdBy == request.auth.uid
        );
        allow write: if isSignedIn() && get(/databases/$(database)/documents/groupWallets/$(groupId)).data.createdBy == request.auth.uid;
      }
    }

    /* ---------- Activities (Real-Time Meetups) ---------- */
    match /activities/{activityId} {
      allow read: if request.auth != null;

      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.get('participants', []) is list
        && request.auth.uid in request.resource.data.get('participants', []);

      allow update: if isSignedIn() && (
        resource.data.createdBy == request.auth.uid ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participants'])
          && request.resource.data.participants is list
          && request.resource.data.participants.hasAll(resource.data.participants)
          && request.auth.uid in request.resource.data.participants
        )
      );

      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;

      match /joinRequests/{requestId} {
        allow create: if isSignedIn();
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/activities/$(activityId)).data.createdBy == request.auth.uid
          || resource.data.userId == request.auth.uid
        );
        allow update: if false;
        allow delete: if isSignedIn() && (
          get(/databases/$(database)/documents/activities/$(activityId)).data.createdBy == request.auth.uid
          || resource.data.userId == request.auth.uid
        );
      }
    }

    /* ---------- Activity Chats ---------- */
    match /activityChats/{activityId} {
      allow read, write: if isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/activities/$(activityId)).data.get('participants', []);
      match /messages/{messageId} {
        allow read, write: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/activities/$(activityId)).data.get('participants', []);
      }
    }

    /* ---------- Activity Memories ---------- */
    match /activityMemories/{memoryId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['activityId', 'videoUrl', 'userId', 'userName', 'createdAt', 'expiresAt', 'latitude', 'longitude'])
        && request.auth.uid in get(/databases/$(database)/documents/activities/$(request.resource.data.activityId)).data.get('participants', []);
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    /* ---------- Future Trips ---------- */
    match /futureTrips/{tripId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['destination', 'startDate', 'endDate', 'userId', 'createdAt'])
        && request.resource.data.destination is string
        && request.resource.data.startDate is string
        && request.resource.data.endDate is string;

      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    /* ---------- Map specials / deals (radius notifications via Cloud Functions) ---------- */
    match /mapSpecials/{specialId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.location is string
        && request.resource.data.location.size() > 0
        && request.resource.data.dealTimeUtc is string
        && request.resource.data.dealTimeUtc.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$')
        && (!('imageUrl' in request.resource.data) || request.resource.data.imageUrl is string)
        && request.resource.data.latitude is number
        && request.resource.data.longitude is number
        && request.resource.data.weekdays is list
        && request.resource.data.weekdays.size() >= 1
        && request.resource.data.active == true;

      allow update: if isSignedIn()
        && resource.data.createdBy == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['createdBy', 'lastNotifiedUtcDate', 'lastNotifiedOccurrenceKey']);

      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;
    }

    /* ---------- Catch-all ---------- */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
