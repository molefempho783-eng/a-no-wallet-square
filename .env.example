# Copy to .env and fill in. Used by the Expo app (EXPO_PUBLIC_* are exposed to the client).

# Required for Lightning wallet (Receive invoice, Send, balance). Point at your backend (see /backend).
# Examples:
#   Same machine, iOS simulator:     http://127.0.0.1:4000
#   Same machine, Android emulator: http://10.0.2.2:4000
#   Device on LAN:                   http://192.168.x.x:4000
EXPO_PUBLIC_SQUARE_API_URL=http://10.0.2.2:4000

# Group wallet “Deposit” (Firebase Callable → backend): set the same backend URL + shared secret
# on Firebase Functions (not in Expo): SQUARE_API_URL, INTERNAL_API_SECRET.
# On the Square backend .env: INTERNAL_API_SECRET (must match Functions).
# Optional on Functions: GROUP_WALLET_ACCESS_PEPPER (defaults to GROUP_WALLET_MNEMONIC for PIN hashing).

# Optional: Klipy API key for GIF search (see services/klipy.ts)
EXPO_PUBLIC_KLIPY_API_KEY=

# Optional: Google Maps (some screens fall back to app.json keys if unset)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
